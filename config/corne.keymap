/* spellchecker:disable */
#include <behaviors/mouse_keys.dtsi>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/backlight.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/ext_power.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/mouse.h>
#include <dt-bindings/zmk/outputs.h>
#include <dt-bindings/zmk/rgb.h>

#define ZMK_MOUSE_DEFAULT_MOVE_VAL 800  // 600
#define ZMK_MOUSE_DEFAULT_SCRL_VAL 20   // 10

#define U_MS_U &mmv MOVE_UP
#define U_MS_D &mmv MOVE_DOWN
#define U_MS_L &mmv MOVE_LEFT
#define U_MS_R &mmv MOVE_RIGHT

#define PSCRN PRINTSCREEN
#define PSBRK PAUSE_BREAK

&lt {
    flavor = "hold-preferred";
    // tapping-term-ms = <150>;
};
&mt {
    // tapping-term-ms = <150>;
};

/ {
    rgb_encoder: rgb_encoder {
        compatible = "zmk,behavior-sensor-rotate";
        label = "RGB_ENCODER";
        #sensor-binding-cells = <0>;
        bindings = <&rgb_ug RGB_BRI>, <&rgb_ug RGB_BRD>;
    };
    scroll_encoder: scroll_encoder  {
        compatible = "zmk,behavior-sensor-rotate";
        #sensor-binding-cells = <0>;
        bindings = <&msc SCRL_DOWN>, <&msc SCRL_UP>;
        tap-ms = <30>;
    };  
    // conditional_layers {
    //     compatible = "zmk,conditional-layers";
    //     tri_layer {
    //         if-layers = <1 2>;
    //         then-layer = <3>;
    //     };
    // };
    macros {
        win_sleep: win_sleep {
            wait-ms = <50>;
            tap-ms = <5>;
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LG(X) &kp U &kp S>;
        };
    };
    behaviors {
        lclk_rclk: lclk_rclk {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            bindings = <&mkp LCLK>, <&mkp RCLK>;
        };
        vol_up_prev: vol_up_prev {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&kp C_VOL_UP>, <&kp C_PREV>;
            mods = <(MOD_LSFT|MOD_RSFT)>;
        };
        vol_dn_next: vol_dn_next {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&kp C_VOL_DN>, <&kp C_NEXT>;
            mods = <(MOD_LSFT|MOD_RSFT)>;
        };
        mute_play_pause: mute_play_pause {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&kp C_MUTE>, <&kp C_PLAY_PAUSE>;
            mods = <(MOD_LSFT|MOD_RSFT)>;
        };
        ls: layer_stick {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "hold-preferred";
            tapping-term-ms = <200>;
            bindings = <&mo>, <&sk>;
        };        
        hs: hold_stick {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "hold-preferred";
            tapping-term-ms = <200>;
            bindings = <&kp>, <&sk>;
        };
        hc: hold_capsword {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "hold-preferred";
            tapping-term-ms = <200>;
            bindings = <&kp>, <&caps_word>;
        };
        mmv {
            acceleration-exponent = <0>;      // 1
            time-to-max-speed-ms = <900>;    // 40
            delay-ms = <0>;                   // 0
        };
        msc {
            acceleration-exponent = <1>;      // 0      
            time-to-max-speed-ms = <400>;      // 500
            delay-ms = <0>;                   // 10
        };
    };


    keymap {
        compatible = "zmk,keymap";
        layer0 {
            display-name = "QWERTY";
            bindings = <
&kp LALT         &kp Q            &kp W            &kp E            &kp R            &kp T            &kp UP           &kp Y            &kp U            &kp I            &kp O            &kp P            &kp RALT
&kp LCTRL        &kp A            &kp S            &kp D            &kp F            &kp G            &kp DOWN         &kp H            &kp J            &kp K            &kp L            &kp SEMI         &kp RCTRL
&kp LSHFT        &kp Z            &kp X            &kp C            &kp V            &kp B            &kp LEFT         &kp N            &kp M            &kp COMMA        &kp DOT          &kp FSLH         &kp RSHFT
&kp C_MUTE                                         &kp LGUI         &lt 1 ESC        &kp SPACE        &kp RIGHT        &kp UNDER        &ls 2 LSHFT      &kp RGUI                                           &kp ENTER >;
            sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN>;
        };
        layer1 {
            display-name = "LOWER";
            bindings = <
&kp LALT         &kp TAB          &kp BSPC         &kp DEL          &kp HOME         &kp END          &mmv MOVE_UP     &kp C_PREV       &kp N7           &kp N8           &kp N9           &kp C_VOL_UP     &kp RALT 
&kp LCTRL        &kp ENTER        &hs LGUI LGUI    &hs LALT LALT    &hs LCTRL LCTRL  &kp PG_UP        &mmv MOVE_DOWN   &kp C_PLAY_PAUSE &kp N4           &kp N5           &kp N6           &kp C_MUTE       &kp RCTRL
&kp LSHFT        &kp LEFT         &kp UP           &kp DOWN         &kp RIGHT        &kp PG_DN        &mmv MOVE_LEFT   &kp C_NEXT       &kp N1           &kp N2           &kp N3           &kp C_VOL_DN     &kp RSHFT
&mkp LCLK                                          &none            &none            &none            &mmv MOVE_RIGHT  &hc LSHFT CAPS   &kp N0           &kp RGUI                                           &mkp RCLK >;
            sensor-bindings = <&scroll_encoder>;
        };
        layer2 {
            display-name = "RAISE";
            bindings = <
&kp LALT         &kp EXCL         &kp AT           &kp POUND        &kp DLLR         &kp PRCNT        &msc SCRL_UP     &kp CARET        &kp AMPS         &kp ASTRK        &kp MINUS        &kp PLUS         &kp RALT
&kp LCTRL        &kp GRAVE        &kp LBRC         &kp LBKT         &kp LPAR         &kp PRINTSCREEN  &msc SCRL_DOWN   &kp INS          &hs RCTRL RCTRL  &hs RALT RALT    &hs RGUI RGUI    &kp SQT          &kp RCTRL
&kp LSHFT        &kp TILDE        &kp RBRC         &kp RBKT         &kp RPAR         &kp PAUSE_BREAK  &msc SCRL_LEFT   &kp K_APP        &kp PIPE         &kp EXCL         &kp TILDE        &kp DQT          &kp RSHFT
&kp C_PLAY_PAUSE                                   &kp LGUI         &mo 3            &hc LSHFT CAPS   &msc SCRL_RIGHT  &none            &none            &none                                              &lclk_rclk >;
            sensor-bindings = <&inc_dec_kp C_PREV C_NEXT>;
        };

        layer3 {
            display-name = "ADJUST";
            bindings = <
&kp LALT         &bt BT_SEL 0     &bt BT_SEL 1     &bt BT_SEL 2     &bt BT_SEL 3     &bt BT_SEL 4     &rgb_ug RGB_BRI  &bt BT_CLR       &kp F7           &kp F8           &kp F9           &kp F12          &kp RALT
&kp LCTRL        &rgb_ug RGB_SPI  &rgb_ug RGB_HUI  &rgb_ug RGB_SAI  &rgb_ug RGB_BRI  &rgb_ug RGB_EFR  &rgb_ug RGB_BRD  &rgb_ug RGB_TOG  &kp F4           &kp F5           &kp F6           &kp F11          &kp RCTRL
&kp LSHFT        &rgb_ug RGB_SPD  &rgb_ug RGB_HUD  &rgb_ug RGB_SAD  &rgb_ug RGB_BRD  &rgb_ug RGB_EFF  &rgb_ug RGB_EFR  &out OUT_TOG     &kp F1           &kp F2           &kp F3           &kp F10          &kp RSHIFT
&bootloader                                        &none           &none             &none            &rgb_ug RGB_EFF  &none            &none            &none                                              &rgb_ug RGB_TOG >;
            sensor-bindings = <&scroll_encoder>;
        };
    };  
};
